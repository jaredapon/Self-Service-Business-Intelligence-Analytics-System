# This is an example environment file.
# Copy it to .env and fill in the values for your environment.
# The default values are set to work with the provided docker-compose.yml.

# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL Database
# Used by Keycloak
POSTGRES_USER=booklatte
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=booklatte
POSTGRES_PORT=5432

# Keycloak Authentication Service
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_secure_password
KEYCLOAK_PORT=8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/booklatte
KEYCLOAK_CLIENT_ID=frontend

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=booklatte
MINIO_ROOT_PASSWORD=your_secure_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_SECURE=false
MINIO_UPLOAD_BUCKET=uploads

# Pipeline Service
TRIGGER_DIR=/app/trigger

# Frontend / CORS
DASH_ALLOW_ORIGINS=http://localhost:5173
DASH_PORT=8050

# Frontend-specific variables (for Vite, etc.)
FRONTEND_PORT=5173
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=booklatte
VITE_KEYCLOAK_CLIENT_ID=frontend
VITE_MINIO_CONSOLE=http://localhost:9001