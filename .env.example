# ===================================================================
# Example Environment File for Business Analytics Platform
# ===================================================================
#
# Copy this file to .env and fill in your actual values.
# The default values are designed to work with the provided docker-compose.yml.
# Replace all instances of 'your_secure_password' with strong, unique passwords.

# ---------------------------------
# Backend API Configuration
# ---------------------------------
# These ports are for the host machine. The container port is fixed at 8000.
API_PORT=8000

# ---------------------------------
# PostgreSQL Database
# ---------------------------------
POSTGRES_HOST=postgres # This is the service name in Docker, not localhost.
POSTGRES_PORT=5432
POSTGRES_USER=booklatte
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=booklatte

# ---------------------------------
# Database Connection Pool (for SQLAlchemy)
# ---------------------------------
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800 # In seconds. Recycles connections after 30 minutes.
DB_POOL_TIMEOUT=30   # In seconds. How long to wait for a connection from the pool.

# ---------------------------------
# Keycloak Authentication Service
# ---------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_secure_password
KEYCLOAK_PORT=8080 # Host port for accessing the Keycloak admin console.

# NOTE: The 'KEYCLOAK_ISSUER' is for your FRONTEND.
# The backend API uses its own internal address ('http://keycloak:8080/...')
# set directly in the docker-compose.yml file.
KEYCLOAK_ISSUER=http://localhost:8080/realms/booklatte

# ---------------------------------
# MinIO Object Storage
# ---------------------------------
MINIO_ROOT_USER=booklatte
MINIO_ROOT_PASSWORD=your_secure_password
MINIO_PORT=9000          # Host port for the MinIO S3 API.
MINIO_CONSOLE_PORT=9001  # Host port for the MinIO Web Console.
MINIO_SECURE=false
MINIO_UPLOAD_BUCKET=uploads

# NOTE: The 'MINIO_ENDPOINT' is for services outside Docker.
# The backend API and observer use their own internal address ('minio:9000')
# set directly in the docker-compose.yml file.
MINIO_ENDPOINT=localhost:9000

# ---------------------------------
# Pipeline Observer Service
# ---------------------------------
# This is an internal path within the backend/observer containers. Do not change.
TRIGGER_DIR=/app/trigger

# ---------------------------------
# Frontend Configuration & CORS
# ---------------------------------
# The backend API will allow requests from this origin.
# Use a comma-separated list for multiple origins.
DASH_ALLOW_ORIGINS=http://localhost:5173

# Port the frontend development server will run on.
FRONTEND_PORT=5173

# Environment variables prefixed with VITE_ are exposed to the frontend code.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=booklatte
VITE_KEYCLOAK_CLIENT_ID=frontend
VITE_MINIO_CONSOLE_URL=http://localhost:9001
VITE_API_BASE_URL=http://localhost:8000

#Gemini 2.5 pro is actually good at designing files what.